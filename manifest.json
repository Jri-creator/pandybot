{
  "manifest_version": 3,
  "name": "PandyBot",
  "version": "1.0.0",
  "description": "Share your Pandora listening activity to Discord via webhook.",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://www.pandora.com/*",
    "https://*.pandora.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.pandora.com/*", "https://*.pandora.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "PandyBot"
  }
}
